<?xml version="1.0" encoding="UTF-8"?>

<?import io.github.palexdev.materialfx.controls.MFXButton?>
<?import io.github.palexdev.materialfx.controls.MFXComboBox?>
<?import io.github.palexdev.materialfx.controls.MFXToggleButton?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane fx:id="root" prefHeight="400.0" prefWidth="400.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="cr.ac.una.astroline.controller.ConfiguracionController">
   <children>
      <VBox alignment="CENTER" layoutX="0.0" layoutY="0.0" spacing="24.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <Label text="Configuración de estación" />
            <MFXComboBox fx:id="cmbSucursal" floatingText="Sucursal" onAction="#onCmbSucursal" prefWidth="320.0" />
            <MFXComboBox fx:id="cmbEstacion" floatingText="Estación" onAction="#onCmbEstacion" prefWidth="320.0" />
            <MFXToggleButton fx:id="tglModulo" onAction="#onTglModulo" onDragDetected="#onTglModulo" text="Esta PC es un Kiosko o pantalla de Proyección" />
            <MFXButton onAction="#onBtnGuardar" prefWidth="320.0" text="Guardar configuración" />
         </children>
         <padding>
            <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
         </padding>
      </VBox>
   </children>
</AnchorPane>
