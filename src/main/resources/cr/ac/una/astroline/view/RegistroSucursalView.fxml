<?xml version="1.0" encoding="UTF-8"?>

<?import io.github.palexdev.materialfx.controls.MFXButton?>
<?import io.github.palexdev.materialfx.controls.MFXTextField?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane fx:id="root" prefHeight="320.0" prefWidth="440.0" styleClass="jfx-root" stylesheets="@Styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="cr.ac.una.astroline.controller.RegistroSucursalController">
   <children>
      <VBox alignment="CENTER" spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>

            <Label fx:id="lblTitulo" alignment="CENTER" maxWidth="1.7976931348623157E308" styleClass="jfx-label-titulo" text="Registro de Sucursal" />

            <MFXTextField fx:id="txtNombre" floatingText="Nombre de la sucursal" maxWidth="1.7976931348623157E308" styleClass="custom-field">
               <VBox.margin>
                  <Insets left="30.0" right="30.0" />
               </VBox.margin>
            </MFXTextField>

            <Label styleClass="jfx-label-subtitulo" text="Texto de aviso (Proyección)" />
            <TextArea fx:id="txtAreaAviso" maxWidth="1.7976931348623157E308" prefHeight="90.0" promptText="Mensaje que corre en ciclo en la pantalla de proyección..." styleClass="custom-field" wrapText="true">
               <VBox.margin>
                  <Insets left="30.0" right="30.0" />
               </VBox.margin>
            </TextArea>

            <HBox alignment="CENTER" spacing="30.0" VBox.vgrow="ALWAYS">
               <children>
                  <MFXButton fx:id="btnGuardar" onAction="#onActionBtnGuardar" styleClass="jfx-btn-principal" text="Guardar" />
                  <MFXButton fx:id="btnCancelar" onAction="#onActionBtnCancelar" styleClass="jfx-btn-principal" text="Cancelar" />
               </children>
            </HBox>

         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
      </VBox>
   </children>
</AnchorPane>
