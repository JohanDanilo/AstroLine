<?xml version="1.0" encoding="UTF-8"?>

<?import io.github.palexdev.materialfx.controls.MFXButton?>
<?import io.github.palexdev.materialfx.controls.MFXComboBox?>
<?import java.net.URL?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="210.0" prefWidth="400.0" styleClass="jfx-root-opcional" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="cr.ac.una.astroline.controller.SeleccionSucursalController">
    <stylesheets>
        <URL value="@Styles.css" />
    </stylesheets>
   <children>
      <Label alignment="CENTER" styleClass="jfx-label-titulo-grande" text="Bienvenido" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="10.0" />
      <VBox alignment="TOP_CENTER" prefHeight="200.0" prefWidth="100.0" spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="45.0">
         <children>
            <Label styleClass="jfx-label-subtitulo-grande" text="Seleccione la sucursal en la que se encuentra" />
            <MFXComboBox fx:id="cmbSeleccionSucursal" styleClass="custom-combo" />
            <MFXButton fx:id="btnConfirmar" onAction="#onConfirmar" styleClass="jfx-btn-principal" text="Aceptar" />
         </children>
      </VBox>
   </children>
</AnchorPane>
