<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="principal-root" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="cr.ac.una.astroline.controller.PrincipalController">

    <!-- HEADER -->
    <top>
        <HBox alignment="CENTER_LEFT" styleClass="header">
            <padding><Insets bottom="12" left="24" right="24" top="12" /></padding>
            <ImageView fx:id="imgLogo" fitHeight="48" fitWidth="48" preserveRatio="true" />
        </HBox>
    </top>

    <!-- CONTENIDO CENTRAL -->
    <center>
        <VBox alignment="CENTER" spacing="40">
            <padding><Insets bottom="60" left="40" right="40" top="60" /></padding>

            <Label styleClass="titulo-bienvenida" text="Seleccione su acceso" />

            <HBox alignment="CENTER" spacing="30">

                <VBox alignment="CENTER" spacing="10" styleClass="access-card">
                    <Label styleClass="access-icon" text="🛡" />
                    <Label styleClass="access-label" text="Administrador" />
                    <Button fx:id="btnAdmin" onAction="#onBtnAdmin" styleClass="btn-acceso" text="Ingresar" />
                </VBox>

                <VBox alignment="CENTER" spacing="10" styleClass="access-card">
                    <Label styleClass="access-icon" text="👔" />
                    <Label styleClass="access-label" text="Funcionario" />
                    <Button fx:id="btnFuncionario" onAction="#irFuncionario" styleClass="btn-acceso" text="Ingresar" />
                </VBox>

                <VBox alignment="CENTER" spacing="10" styleClass="access-card">
                    <Label styleClass="access-icon" text="🖥" />
                    <Label styleClass="access-label" text="Kiosko" />
                    <Button fx:id="btnKiosko" onAction="#irKiosko" styleClass="btn-acceso" text="Ingresar" />
                </VBox>

                <VBox alignment="CENTER" spacing="10" styleClass="access-card">
                    <Label styleClass="access-icon" text="📺" />
                    <Label styleClass="access-label" text="Proyección" />
                    <Button fx:id="btnProyeccion" onAction="#irProyeccion" styleClass="btn-acceso" text="Ingresar" />
                </VBox>

            </HBox>
        </VBox>
    </center>

    <!-- FOOTER -->
    <bottom>
        <HBox alignment="CENTER">
            <padding><Insets bottom="10" top="10" /></padding>
            <Label fx:id="lblVersion" styleClass="footer-texto" text="AstroLine v1.0 · Universidad Nacional de Costa Rica" />
        </HBox>
    </bottom>

</BorderPane>
