<?xml version="1.0" encoding="UTF-8"?>

<?import io.github.palexdev.materialfx.controls.MFXButton?>
<?import io.github.palexdev.materialfx.controls.MFXTextField?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>


<AnchorPane prefHeight="500.0" prefWidth="700.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="cr.ac.una.astroline.controller.MantenimientoSucursalController">
   <children>
      <VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" spacing="5.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <Label fx:id="lblSucursal" alignment="CENTER" maxWidth="1.7976931348623157E308" text="Sucursal :  Nombre" textAlignment="CENTER" VBox.vgrow="ALWAYS" />
            <HBox maxWidth="1.7976931348623157E308" prefHeight="47.0" prefWidth="600.0" spacing="5.0">
               <children>
                  <MFXTextField fx:id="txtBarraBusquedaEstaciones" floatingText="Buscar" maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS" />
                  <MFXButton fx:id="btnAgregar" maxHeight="1.7976931348623157E308" onAction="#onActionBtnAgregar" text="Agregar" HBox.hgrow="ALWAYS" />
               </children>
               <padding>
                  <Insets bottom="3.0" left="3.0" right="3.0" top="3.0" />
               </padding>
            </HBox>
            <HBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" VBox.vgrow="ALWAYS">
               <children>
                  <VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="508.0" prefWidth="328.0" spacing="5.0" HBox.hgrow="ALWAYS">
                     <children>
                        <Label alignment="CENTER" maxWidth="1.7976931348623157E308" text="Estaciones" VBox.vgrow="ALWAYS" />
                        <ListView fx:id="listaEstaciones" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" onKeyPressed="#onKeyPressedEstaciones" onMousePressed="#onMousePressedEstaciones" prefHeight="490.0" prefWidth="400.0" VBox.vgrow="ALWAYS" />
                     </children>
                     <padding>
                        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                     </padding>
                  </VBox>
                  <VBox alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefWidth="245.0" spacing="5.0" HBox.hgrow="ALWAYS">
                     <children>
                        <Label text="Tramites Asignados" />
                        <TableView fx:id="tableTramitesAsignados" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" onDragDetected="#onDragDetectedAsignados" onDragDone="#onDragDoneAsignados" onDragDropped="#onDragDroppedAsignados" onDragEntered="#onDragEnteredAsignados" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
                           <columns>
                              <TableColumn fx:id="colTramiteAsignado" prefWidth="75.0" text="Tramite" />
                              <TableColumn fx:id="colEstadoAsignado" prefWidth="75.0" text="Estado" />
                           </columns>
                           <columnResizePolicy>
                              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                           </columnResizePolicy>
                        </TableView>
                        <Label alignment="CENTER" maxWidth="1.7976931348623157E308" text="Tramites Disponibles" VBox.vgrow="ALWAYS" />
